#!/bin/sh
# Exit on any error
set -e

# Check if there are any staged files
if [ -z "$(git diff --cached --name-only)" ]; then
  echo "No staged files to format"
  exit 0
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
PARTIAL_FILES=$(printf "%s\n" "$STAGED_FILES" | while IFS= read -r file; do
  [ -n "$file" ] || continue
  git diff --quiet -- "$file" || printf "%s\n" "$file"
done)

if [ -n "$PARTIAL_FILES" ]; then
  echo "❌ Partially staged files are not supported by pre-commit:"
  printf "%s\n" "$PARTIAL_FILES"
  echo "Stage or stash the full file and retry."
  exit 1
fi

STAGED_HASH=$(git diff --cached | sha256sum | cut -d' ' -f1)
STASH_BEFORE=$(git rev-parse -q --verify refs/stash || true)
git stash push --quiet --keep-index --include-untracked --message "pre-commit-stash" >/dev/null 2>&1 || true
STASH_AFTER=$(git rev-parse -q --verify refs/stash || true)
CREATED_STASH=0

if [ "$STASH_BEFORE" != "$STASH_AFTER" ]; then
  CREATED_STASH=1
fi

restore_stash() {
  if [ "$CREATED_STASH" -eq 1 ]; then
    git stash pop --quiet >/dev/null 2>&1 || true
  fi
}

trap restore_stash EXIT

bun x ultracite fix $STAGED_FILES

echo "$STAGED_FILES" | while IFS= read -r file; do
  if [ -f "$file" ]; then
    git add "$file"
  fi
done

# Check if staged files actually changed
NEW_STAGED_HASH=$(git diff --cached | sha256sum | cut -d' ' -f1)
if [ "$STAGED_HASH" != "$NEW_STAGED_HASH" ]; then
  echo "🎨 Files formatted by Ultracite"
fi

echo "🔍 Running lint"
bun run lint
LINT_EXIT_CODE=$?
if [ $LINT_EXIT_CODE -ne 0 ]; then
  echo "❌ Lint failed. Please fix before committing."
  exit $LINT_EXIT_CODE
fi

echo "✅ Lint completed successfully"

echo "🧪 Running tests"
bun test
TEST_EXIT_CODE=$?
if [ $TEST_EXIT_CODE -ne 0 ]; then
  echo "❌ Tests failed. Please fix before committing."
  exit $TEST_EXIT_CODE
fi

echo "✅ Tests completed successfully"

echo "🔨 Running build"
bun run build
BUILD_EXIT_CODE=$?
if [ $BUILD_EXIT_CODE -ne 0 ]; then
  echo "❌ Build failed. Please fix before committing."
  exit $BUILD_EXIT_CODE
fi

echo "🏗️ Build completed successfully"

exit 0
