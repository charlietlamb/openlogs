{
  "name": "openlogs",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@biomejs/biome": "^2.4.6",
      "@databuddy/sdk": "^2.3.29",
      "@phosphor-icons/react": "^2.1.10",
      "@tailwindcss/postcss": "^4",
      "@types/node": "^20",
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "clsx": "^2.1.1",
      "husky": "^9.1.7",
      "next": "16.1.6",
      "next-themes": "^0.4.6",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "tailwind-merge": "^3.5.0",
      "tailwindcss": "^4",
      "turbo": "^2.5.4",
      "typescript": "^5",
      "ultracite": "^7.2.4"
    }
  },
  "scripts": {
    "dev": "turbo dev --filter=web",
    "build": "turbo build --filter=web",
    "test": "bun test",
    "bump": "cd packages/ol && bun bump",
    "patch": "cd packages/ol && bun patch",
    "lint": "bun run --cwd apps/web lint",
    "lint:fix": "bunx biome lint --write .",
    "format": "bunx biome format --write .",
    "check": "bunx biome check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "husky": "catalog:",
    "turbo": "catalog:",
    "ultracite": "catalog:"
  },
  "packageManager": "bun@1.2.5"
}
